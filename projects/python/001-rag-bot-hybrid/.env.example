# Required for ingest
OPENAI_API_KEY=

# Store URLs
ELASTICSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333

# Ingest: directory with PDFs and index/collection names
DATA_DIR=./data
DATA_PROCESSED_DIR=./data/processed
ES_INDEX_NAME=hybrid-docs
QDRANT_COLLECTION_NAME=hybrid-docs

# Optional: OpenAI embedding model (default: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Embedding vector dimension (must match model; text-embedding-3-small = 1536)
OPENAI_EMBEDDING_DIM=1536
# Embedding API batch size (chunks per request; max ~300k tokens/request)
EMBED_BATCH_SIZE=1000
# Text chunking: size and overlap in characters
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Hybrid search defaults
HYBRID_BM25_WEIGHT=0.4

HYBRID_VECTOR_WEIGHT=0.6

# Hybrid search candidate size per retriever (ES and Qdrant)
HYBRID_TOP_K=50

# Hybrid search final results returned after fusion/ranking
HYBRID_RETURN_K=20

# Fusion baseline selection: weighted_minmax (default) or rrf
HYBRID_FUSION_METHOD=weighted_minmax
# RRF stabilizer constant (commonly 60)
HYBRID_RRF_K=60

# Streamlit eval logging (JSONL)
EVAL_LOG_PATH=./eval_runs.jsonl

# OpenAI chat (answer) and judge models
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4.1

# Required for ingest
OPENAI_API_KEY=

# Store URLs
ELASTICSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333

# Ingest: directory with PDFs and index/collection names
DATA_DIR=./data
DATA_PROCESSED_DIR=./data/processed
ES_INDEX_NAME=hybrid-docs
QDRANT_COLLECTION_NAME=hybrid-docs

# Optional: OpenAI embedding model (default: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Embedding vector dimension (must match model; text-embedding-3-small = 1536)
OPENAI_EMBEDDING_DIM=1536
# Embedding API batch size (chunks per request; max ~300k tokens/request)
EMBED_BATCH_SIZE=1000
# Text chunking: size and overlap in characters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
